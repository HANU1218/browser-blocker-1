<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.browserlocker.app">

    <!-- Permissions needed -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <application
        android:allowBackup="false"
        android:label="System Service"
        android:theme="@style/AppTheme">

        <!--
            NO <activity> with LAUNCHER intent here.
            This means the app has NO icon in the app drawer.
            User cannot open it directly.
        -->

        <!-- Device Admin Receiver — required for Device Owner -->
        <receiver
            android:name=".MyDeviceAdminReceiver"
            android:description="@string/admin_description"
            android:label="@string/admin_label"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <!-- Boot Receiver — starts the blocker service on device boot -->
        <receiver
            android:name=".BootReceiver"
            android:exported="false">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- Package Install Receiver — detects new app installs in real-time -->
        <receiver
            android:name=".PackageInstallReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <action android:name="android.intent.action.PACKAGE_REPLACED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <!-- Background Service — keeps blocking active -->
        <service
            android:name=".BrowserBlockerService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

    </application>
</manifest>
